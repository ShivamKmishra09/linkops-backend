NODE_ENV=production
PORT=8000
DB_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/linkops
REDIS_URL=rediss://:PASSWORD@REDIS_NAME.redis.cache.windows.net:6380
JWT_KEY=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-secret
BIFROST_API_KEY=replace-with-valid-bifrost-virtual-key
BIFROST_CHAT_COMPLETIONS_URL=https://gateway-buildathon.ltl.sh/v1/chat/completions
BIFROST_MODEL=gpt-4o
REACT_APP_FRONTEND_URL=https://linkops-frontend.vercel.app
AUTH_PROFILE_ENCRYPTION_KEY=replace-with-32-byte-base64-or-long-secret
CONNECTOR_ENCRYPTION_KEY=replace-with-32-byte-base64-or-long-secret
GOOGLE_OAUTH_CLIENT_ID=optional-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=optional-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_API_FQDN/connectors/google/callback
