NODE_ENV=production
PORT=8000
# docker-compose.aws.yml overrides this with mongodb://mongo:27017/linkops.
# Use a MongoDB Atlas URI here only if you remove that override.
DB_URL=mongodb://mongo:27017/linkops
JWT_KEY=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-secret
BIFROST_API_KEY=replace-with-valid-bifrost-virtual-key
BIFROST_CHAT_COMPLETIONS_URL=https://gateway-buildathon.ltl.sh/v1/chat/completions
BIFROST_MODEL=gpt-4o
REACT_APP_FRONTEND_URL=https://linkops-frontend.vercel.app
AUTH_PROFILE_ENCRYPTION_KEY=replace-with-long-random-secret
CONNECTOR_ENCRYPTION_KEY=replace-with-long-random-secret
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://YOUR_EC2_PUBLIC_IP:8000/connectors/google/callback
